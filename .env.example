# Cue public configuration
#
# Precedence rule:
# 1. CUE_* values
# 2. deprecated BROOD_* compatibility aliases
# 3. built-in defaults

# Preferred runtime directories
CUE_HOME_DIR=$HOME/.cue
CUE_RUN_ROOT=$HOME/cue_runs

# Deprecated compatibility aliases
# BROOD_HOME_DIR=$HOME/.brood
# BROOD_RUN_ROOT=$HOME/brood_runs

# Bridge / automation socket
CUE_DESKTOP_BRIDGE_SOCKET=/tmp/cue_desktop_bridge.sock
# BROOD_DESKTOP_BRIDGE_SOCKET=/tmp/brood_desktop_bridge.sock

# Optional release token for GitHub release API calls
CUE_RELEASE_TOKEN=
# BROOD_RELEASE_TOKEN=

# Install telemetry for smoke and release checks
CUE_INSTALL_TELEMETRY=0
CUE_INSTALL_TELEMETRY_RESET=0
CUE_INSTALL_TELEMETRY_FORCE=0
CUE_INSTALL_TELEMETRY_ENDPOINT=
CUE_INSTALL_TELEMETRY_INSTALL_ID=
# BROOD_INSTALL_TELEMETRY=0
# BROOD_INSTALL_TELEMETRY_RESET=0
# BROOD_INSTALL_TELEMETRY_FORCE=0
# BROOD_INSTALL_TELEMETRY_ENDPOINT=
# BROOD_INSTALL_TELEMETRY_INSTALL_ID=

# Realtime routing
CUE_REALTIME_PROVIDER=
CUE_CANVAS_CONTEXT_REALTIME_PROVIDER=
CUE_INTENT_REALTIME_PROVIDER=
CUE_MOTHER_INTENT_REALTIME_PROVIDER=
CUE_CANVAS_CONTEXT_REALTIME_MODEL=
CUE_INTENT_REALTIME_MODEL=
CUE_MOTHER_INTENT_REALTIME_MODEL=

# OpenRouter request metadata
CUE_OPENROUTER_HTTP_REFERER=
CUE_OPENROUTER_X_TITLE=Cue
# BROOD_OPENROUTER_HTTP_REFERER=
# BROOD_OPENROUTER_X_TITLE=

# Provider API keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
