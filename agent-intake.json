{
  "schema_version": "aip-1",
  "schema": {
    "url": "https://raw.githubusercontent.com/kevinshowkat/cue/main/docs/aip-1.schema.json",
    "local_path": "docs/aip-1.schema.json",
    "request_def": "#/$defs/IntakeRequest",
    "response_def": "#/$defs/IntakeResponse"
  },
  "intake_endpoint": "https://6yq5plinssvsog2ozyhnfnscya0qwdzp.lambda-url.us-east-1.on.aws/aip/intake",
  "notes": [
    "This file describes an optional intake endpoint for tooling.",
    "If intake is unavailable, use llms.txt and the fallback entrypoints listed here.",
    "For status and example flow, see docs/agent_intake_status.md and docs/agent_intake_roundtrip.sample.json."
  ],
  "intake_status_cue": {
    "healthy_when": [
      "HTTP 200 response from intake_endpoint",
      "valid JSON response",
      "schema_version == aip-1",
      "response.entrypoints is non-empty"
    ],
    "degraded_when": [
      "timeout or network failure",
      "non-2xx response",
      "invalid JSON or wrong schema version",
      "missing or empty entrypoints"
    ],
    "fallback_path": [
      "llms.txt",
      "docs/agent_quickstart.md",
      "fallback_entrypoints"
    ],
    "status_doc": "docs/agent_intake_status.md",
    "roundtrip_example": "docs/agent_intake_roundtrip.sample.json"
  },
  "privacy": {
    "purpose": "Return curated entrypoints for common task areas and optionally log coarse task tags.",
    "expected_logs": [
      "timestamp",
      "agent.tool",
      "agent.tool_version",
      "task.tags",
      "repo.ref (if provided)",
      "response.packs[].id (if any)"
    ],
    "do_not_send": [
      "API keys or secrets",
      "source images / binary artifacts"
    ],
    "opt_out": {
      "request_field": "telemetry.opt_out",
      "header": "X-Cue-Opt-Out",
      "header_value": "1"
    }
  },
  "tags": [
    "desktop",
    "runtime",
    "release",
    "docs"
  ],
  "fallback_entrypoints": [
    {
      "path": "README.md",
      "kind": "doc",
      "why": "Project summary and quick start.",
      "priority": 1
    },
    {
      "path": "PRD.md",
      "kind": "doc",
      "why": "Short product overview and current public scope.",
      "priority": 1
    },
    {
      "path": "AGENTS.md",
      "kind": "doc",
      "why": "Repository workflow and common checks.",
      "priority": 1
    },
    {
      "path": "docs/README.md",
      "kind": "doc",
      "why": "Docs index.",
      "priority": 2
    },
    {
      "path": "docs/desktop.md",
      "kind": "doc",
      "why": "Desktop app behavior and saved files.",
      "priority": 2
    },
    {
      "path": "RELEASING.md",
      "kind": "doc",
      "why": "Release and packaging guide.",
      "priority": 2
    },
    {
      "path": "docs/legacy-internals.md",
      "kind": "doc",
      "why": "Older internal names still present in the codebase.",
      "priority": 2
    },
    {
      "path": "rust_engine/crates/brood-cli/src/main.rs",
      "kind": "source",
      "why": "Native CLI entrypoint.",
      "priority": 2
    },
    {
      "path": "rust_engine/crates/brood-engine/src/lib.rs",
      "kind": "source",
      "why": "Native runtime orchestration.",
      "priority": 2
    },
    {
      "path": "desktop/src/canvas_app.js",
      "kind": "source",
      "why": "Desktop canvas behavior.",
      "priority": 2
    },
    {
      "path": "desktop/src-tauri/src/main.rs",
      "kind": "source",
      "why": "Tauri backend entrypoint.",
      "priority": 3
    },
    {
      "path": "desktop/src-tauri/tauri.conf.json",
      "kind": "config",
      "why": "App and file-scope configuration.",
      "priority": 3
    },
    {
      "path": "scripts/dev_desktop.sh",
      "kind": "script",
      "why": "Local desktop dev runner.",
      "priority": 2
    }
  ],
  "tag_catalog": {
    "desktop": {
      "description": "Desktop app behavior, canvas changes, and UI fixes.",
      "entrypoints": [
        "README.md",
        "desktop/src/canvas_app.js",
        "desktop/src/index.html",
        "desktop/src/styles.css",
        "docs/desktop.md",
        "desktop/src-tauri/src/main.rs",
        "desktop/src-tauri/tauri.conf.json"
      ]
    },
    "runtime": {
      "description": "Native runtime, events, and compatibility details.",
      "entrypoints": [
        "rust_engine/crates/brood-cli/src/main.rs",
        "rust_engine/crates/brood-engine/src/lib.rs",
        "rust_engine/crates/brood-contracts/src/events.rs",
        "docs/legacy-internals.md",
        ".env.example"
      ]
    },
    "release": {
      "description": "Versioning, packaging, and publishing.",
      "entrypoints": [
        "RELEASING.md",
        "scripts/release_check.sh",
        ".github/workflows/publish.yml",
        ".github/workflows/desktop-clean-machine-smoke.yml",
        "desktop/src-tauri/tauri.conf.json"
      ]
    },
    "docs": {
      "description": "Project and documentation updates.",
      "entrypoints": [
        "README.md",
        "PRD.md",
        "AGENTS.md",
        "CONTRIBUTING.md",
        "docs/README.md",
        "docs/desktop.md",
        "docs/legacy-internals.md",
        "docs/agent-runtime.md",
        "docs/agent_quickstart.md"
      ]
    }
  },
  "client_hints": {
    "agent": {
      "tool": "codex",
      "git_user_agent": "git/2.x"
    }
  }
}
