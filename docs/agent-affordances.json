      "label": "Design Review",
      "surface": "review",
      "source": "review_button",
      "whatItDoes": "Generates ranked action-first edit proposals from visible canvas state plus current focus hints.",
      "whenToUse": [
        "ambiguous user goals",
        "aesthetic improvement tasks",
        "when multiple edit strategies may work"
      ],
      "whenNotToUse": [
        "obvious direct single-step edits",
        "blind repeated retries without new focus"
      ],
      "requiresImage": false,
      "requiresFocus": true,
      "mutatesPixels": false,
      "reversible": true,
      "executionType": "design_review_request",
      "routeProfileId": "design_review_planner_v1",
      "costClass": "low_to_medium",
      "latencyClass": "medium",
      "returns": {
        "proposalCountMin": 2,
        "proposalCountMax": 3,
        "includesPreviewJobs": true
