{
  "schemaVersion": "juggernaut-agent-affordances-v1",
  "lastUpdated": "2026-03-26",
  "notes": [
    "This manifest is a first-pass machine-readable catalog for agent-operated Juggernaut workflows.",
    "Affordances are agent-facing descriptions of what operations do; execution types remain internal stable runtime identifiers.",
    "Provider and model details belong primarily to route profiles and receipts, not to the semantic identity of an affordance.",
    "The current visible right-side communication rail exposes Marker, Protect, Magic Select, and Eraser; make_space remains documented as a dormant runtime affordance."
  ],
  "executionTypes": [
    {
      "id": "subject_isolation",
      "kind": "pixel_edit",
      "description": "Separate a main subject from surrounding background content.",
      "mutatesPixels": true,
      "reversible": true,
      "defaultRouteProfileId": "subject_isolation_default_v1",
      "currentEntryPoints": [
        "cut_out",
        "design_review_proposal"
      ]
    },
    {
      "id": "targeted_remove",
      "kind": "pixel_edit",
      "description": "Remove targeted content and plausibly fill or repair the affected area.",
      "mutatesPixels": true,
      "reversible": true,
      "defaultRouteProfileId": "targeted_remove_default_v1",
      "currentEntryPoints": [
        "remove",
        "design_review_proposal"
      ]
    },
    {
      "id": "background_replace",
      "kind": "pixel_edit",
      "description": "Replace or reinterpret background content while preserving the main subject.",
      "mutatesPixels": true,
      "reversible": true,
      "defaultRouteProfileId": "background_replace_default_v1",
      "currentEntryPoints": [
        "new_background",
        "design_review_proposal"
      ]
    },
    {
      "id": "crop_or_outpaint",
      "kind": "pixel_edit",
      "description": "Reframe composition by cropping or extending beyond current image edges.",
      "mutatesPixels": true,
      "reversible": true,
      "defaultRouteProfileId": "crop_or_outpaint_default_v1",
      "currentEntryPoints": [
        "reframe",
        "design_review_proposal"
      ]
    },
    {
      "id": "identity_preserving_variation",
      "kind": "pixel_edit",
      "description": "Generate image variants that preserve core subject identity and intent.",
      "mutatesPixels": true,
      "reversible": true,
      "defaultRouteProfileId": "identity_preserving_variation_default_v1",
      "currentEntryPoints": [
        "variants",
        "design_review_proposal"
      ]
    },
    {
      "id": "communication_mark",
      "kind": "focus_overlay",
      "description": "Add a temporary spatial focus hint without changing image pixels.",
      "mutatesPixels": false,
      "reversible": true,
      "defaultRouteProfileId": null,
      "currentEntryPoints": [
        "marker"
      ]
    },
    {
      "id": "region_candidate_select",
      "kind": "focus_overlay",
      "description": "Generate or cycle candidate target regions near a clicked location.",
